{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "project"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "default": "project title",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "default": "web app",
      "enum": [
        "desktop app",
        "mobile app",
        "web app",
        "operating systems",
        "experimentation"
      ]
    },
    "date_start": {
      "type": "date",
      "required": true
    },
    "date_end": {
      "type": "date",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "is_ongoing"
            },
            true
          ]
        }
      }
    },
    "is_ongoing": {
      "type": "boolean"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "language": {
      "type": "enumeration",
      "required": true,
      "default": "indonesian",
      "enum": [
        "english",
        "indonesian"
      ]
    },
    "content": {
      "type": "richtext"
    }
  }
}
